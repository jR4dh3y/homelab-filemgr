---
export interface Props {
  icon: any; // Astro component
  label: string;
  active?: boolean;
}

const { icon: Icon, label, active = false } = Astro.props;
---

<button class={`w-full flex items-center gap-2.5 py-1.5 px-3 pl-5 ${active ? 'bg-selection text-white' : 'text-text-primary hover:bg-surface-secondary'}`}>
  <Icon class="w-4 h-4 opacity-80" />
  <span class="flex-1 text-left">{label}</span>
</button>
